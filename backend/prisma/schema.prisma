generator client {
  provider = "prisma-client"
  output   = "../server/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  DEVELOPER
  ADMIN
  RH
  MANAGER
  EMPLOYEE
}

enum RecordStatus {
  DRAFT
  NORMAL
  OVERTIME
  ABSENCE
  COMPENSATION
}

enum TimeRecordReviewStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  ADJUSTED
}

enum JustificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  SYSTEM
  APPROVAL
  WARNING
  INFO
  SECURITY
}

enum ContractType {
  CLT
  PJ
  ESTAGIO
}

enum PointType {
  ENTRY
  BREAK_START
  BREAK_END
  EXIT
}

enum TicketStatus {
  ABERTO
  EM_ANALISE
  AGUARDANDO_RESPOSTA
  RESOLVIDO
  ENCERRADO
}

enum TicketCategory {
  SUPORTE_TECNICO
  JORNADA_E_PONTO
  RH_E_BENEFICIOS
  ACESSO_E_PERMISSOES
  SUGESTOES_E_MELHORIAS
  OUTROS
}

enum IntegrationProvider {
  GOOGLE_CALENDAR
  SLACK
  MICROSOFT_TEAMS
  OUTLOOK
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  document  String?
  phone     String?
  address   String?
  logo      String?
  isActive  Boolean  @default(true)

  plan        String  @default("starter")
  userLimit   Int     @default(20)
  contractAt  DateTime?
  status      String  @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  branches    Branch[]
  departments Department[]
  positions   Position[]
  config      CompanyConfig?
  tickets     Ticket[]

  @@map("companies")
}

model Branch {
  id          String   @id @default(cuid())
  name        String
  code        String?
  cnpj        String?
  address     String?
  city        String?
  state       String?
  zip         String?
  phone       String?
  responsible String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  users User[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("branches")
}

model Department {
  id        String      @id @default(cuid())
  name      String
  active    Boolean     @default(true)
  order     Int         @default(0)
  createdAt DateTime    @default(now())

  positions Position[]
  users     User[]

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([order])
  @@map("departments")
}

model Position {
  id           String      @id @default(cuid())
  name         String
  active       Boolean     @default(true)
  departmentId String
  department   Department  @relation(fields: [departmentId], references: [id])
  createdAt    DateTime    @default(now())

  users        User[]

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([departmentId])
  @@index([companyId])
  @@map("positions")
}

model User {
  id                     String     @id @default(cuid())
  email                  String     @unique
  password               String
  name                   String
  cpf                    String?    @unique
  phone                  String?
  avatar                 String?
  role                   UserRole   @default(EMPLOYEE)
  department             String?
  departmentId           String?
  departmentRel          Department?  @relation(fields: [departmentId], references: [id])
  position               String?
  positionId             String?
  positionRel            Position?    @relation(fields: [positionId], references: [id])
  contractType           ContractType?
  employeeCode           String?
  weeklyHours            Int        @default(40)
  workSchedule           String     @default("Seg-Sex")
  hireDate               DateTime   @default(now())
  birthDate              DateTime?
  address                String?
  isActive               Boolean    @default(true)
  lastAccessAt           DateTime?

  registrationNumber     String?    @unique

  emailVerified          Boolean    @default(false)
  verificationCode       String?
  verificationExpiresAt  DateTime?

  reportNotificationDay  Int        @default(1)

  themeMode              String     @default("system")
  themeAccent            String     @default("blue")

  permissions            Json?      @default("[]")

  resetPasswordCode      String?
  resetPasswordExpiresAt DateTime?

  refreshTokenHash      String?
  refreshTokenExpiresAt DateTime?

  refreshTokenVersion   Int      @default(0)

  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  branchId  String?
  branch    Branch? @relation(fields: [branchId], references: [id])

  timeRecords          TimeRecord[]
  reviewedRecords      TimeRecord[]        @relation("TimeRecordReviewer")
  justifications Justification[]
  notifications  Notification[]
  activityLogs        ActivityLog[]       @relation("ActivityLogActor")
  targetedActivityLogs ActivityLog[]       @relation("ActivityLogTarget")
  documents           Document[]
  uploadedDocuments   Document[]          @relation("DocumentUploader")
  pointEvents         PointEvent[]
  integrations        Integration[]
  termAcceptance      TermAcceptance?
  faceRegistration    FaceRegistration?
  tickets             Ticket[]
  assignedTickets     Ticket[]             @relation("TicketAssignee")
  ticketMessages      TicketMessage[]

  @@index([companyId])
  @@index([branchId])
  @@index([email])
  @@index([role])
  @@index([cpf])
  @@map("users")
}

model TimeRecord {
  id              String       @id @default(cuid())
  clockIn         String
  clockOut        String?
  breakStart      String?
  breakEnd        String?
  totalMinutes    Int?
  overtimeMinutes Int          @default(0)
  status          RecordStatus @default(NORMAL)
  description     String?
  date            DateTime     @map("date") @db.Date
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  reviewStatus   TimeRecordReviewStatus? @default(PENDING_REVIEW)
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewNote     String?

  reviewer       User? @relation("TimeRecordReviewer", fields: [reviewedBy], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  pointEvents PointEvent[]

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@index([status])
  @@map("time_records")
}

model PointEvent {
  id              String    @id @default(cuid())
  pointType       PointType
  timeValue       String
  recordedAt      DateTime  @default(now())
  latitude        Float?
  longitude       Float?
  locationAccuracy Float?
  locationAddress String?
  locationCity    String?
  locationState   String?
  deviceInfo      Json?
  photoData       String?
  hasPhoto        Boolean   @default(false)
  passwordVerified Boolean  @default(false)
  faceVerified    Boolean?
  date            DateTime  @map("date") @db.Date

  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeRecordId String?
  timeRecord   TimeRecord? @relation(fields: [timeRecordId], references: [id])

  @@index([userId, date])
  @@index([date])
  @@map("point_events")
}

model Justification {
  id            String              @id @default(cuid())
  reason        String
  description   String?
  status        JustificationStatus @default(PENDING)
  rhResponse    String?
  startDate     DateTime            @db.Date
  endDate       DateTime            @db.Date
  attachmentUrl String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  respondedBy String?

  @@index([userId])
  @@index([status])
  @@map("justifications")
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType @default(INFO)
  read      Boolean          @default(false)
  link      String?
  metadata  Json?
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([userId, read])
  @@map("notifications")
}

model ActivityLog {
  id           String   @id @default(cuid())
  action       String
  description  String?
  entityType   String?
  entityId     String?
  oldValue     String?
  newValue     String?
  metadata     Json?
  timestamp    DateTime @default(now())

  userId       String
  user         User     @relation("ActivityLogActor", fields: [userId], references: [id], onDelete: Cascade)
  targetUserId String?
  targetUser   User?    @relation("ActivityLogTarget", fields: [targetUserId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@map("activity_logs")
}

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String
  category    String
  fileUrl     String
  fileSize    Int?
  mimeType    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploadedBy  String
  uploader    User     @relation("DocumentUploader", fields: [uploadedBy], references: [id])

  @@index([userId])
  @@index([category])
  @@index([type])
  @@map("documents")
}

model Integration {
  id             String              @id @default(cuid())
  provider       IntegrationProvider
  name           String
  description    String?
  isConnected    Boolean             @default(false)
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  lastSyncAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("integrations")
}

model TermAcceptance {
  id        String   @id @default(cuid())
  acceptedAt DateTime @default(now())
  ip        String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("term_acceptances")
}

model FaceRegistration {
  id          String   @id @default(cuid())
  status      String   @default("COMPLETED")
  descriptors Json?
  images      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("face_registrations")
}

model Ticket {
  id            String         @id @default(cuid())
  protocol      String         @unique
  title         String
  description   String
  category      TicketCategory
  subcategory   String
  status        TicketStatus   @default(ABERTO)
  priority      String         @default("media")
  assignedTo    String?
  userId        String
  companyId     String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user        User              @relation(fields: [userId], references: [id])
  company     Company           @relation(fields: [companyId], references: [id])
  assignee    User?             @relation("TicketAssignee", fields: [assignedTo], references: [id])
  messages    TicketMessage[]
  attachments TicketAttachment[]

  @@index([companyId])
  @@index([userId])
  @@index([status])
  @@index([assignedTo])
  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  message   String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@map("ticket_messages")
}

model TicketAttachment {
  id        String   @id @default(cuid())
  ticketId  String
  fileUrl   String
  fileName  String
  mimeType  String
  fileSize  Int
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_attachments")
}

model MonthClosing {
  id        String   @id @default(cuid())
  companyId String
  year      Int
  month     Int
  status    String   @default("open")
  closedAt  DateTime?
  closedBy  String?
  reopenedAt DateTime?
  reopenedBy String?

  @@unique([companyId, year, month])
  @@index([companyId])
  @@index([status])
  @@map("month_closings")
}

model CompanyConfig {
  id                  String   @id @default(cuid())
  logo               String?
  primaryColor       String   @default("#3B82F6")
  requireGeo         Boolean  @default(false)
  requireFace        Boolean  @default(false)
  defaultWeeklyHours Int      @default(40)
  lunchDuration      Int      @default(60)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  companyId String @unique
  company   Company @relation(fields: [companyId], references: [id])

  @@map("company_configs")
}
