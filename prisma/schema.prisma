generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  DEVELOPER
  ADMIN
  RH
  EMPLOYEE
}

enum RecordStatus {
  DRAFT
  NORMAL
  OVERTIME
  ABSENCE
  COMPENSATION
}

enum TimeRecordReviewStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  ADJUSTED
}

enum JustificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  SYSTEM
  APPROVAL
  WARNING
  INFO
  SECURITY
}

enum ContractType {
  CLT
  PJ
  ESTAGIO
}

enum PointType {
  ENTRY
  BREAK_START
  BREAK_END
  EXIT
}

enum IntegrationProvider {
  GOOGLE_CALENDAR
  SLACK
  MICROSOFT_TEAMS
  OUTLOOK
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  document  String?
  phone     String?
  address   String?
  logo      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@map("companies")
}

model Department {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  active    Boolean     @default(true)
  order     Int         @default(0)
  createdAt DateTime    @default(now())

  positions Position[]
  users     User[]

  @@index([slug])
  @@index([order])
  @@map("departments")
}

model Position {
  id           String      @id @default(cuid())
  name         String
  slug         String      @unique
  active       Boolean     @default(true)
  departmentId String
  department   Department  @relation(fields: [departmentId], references: [id])
  createdAt    DateTime    @default(now())

  users        User[]

  @@index([departmentId])
  @@index([slug])
  @@map("positions")
}

model User {
  id                     String     @id @default(cuid())
  email                  String     @unique
  password               String
  name                   String
  cpf                    String?    @unique
  phone                  String?
  avatar                 String?
  role                   UserRole   @default(EMPLOYEE)
  department             String?
  departmentId           String?
  departmentRel          Department?  @relation(fields: [departmentId], references: [id])
  position               String?
  positionId             String?
  positionRel            Position?    @relation(fields: [positionId], references: [id])
  contractType           ContractType?
  employeeCode           String?
  weeklyHours            Int        @default(40)
  workSchedule           String     @default("Seg-Sex")
  hireDate               DateTime   @default(now())
  birthDate              DateTime?
  address                String?
  isActive               Boolean    @default(true)
  lastAccessAt           DateTime?

  registrationNumber     String?    @unique

  emailVerified          Boolean    @default(false)
  verificationCode       String?
  verificationExpiresAt  DateTime?

  reportNotificationDay  Int        @default(1)

  themeMode              String     @default("system")
  themeAccent            String     @default("blue")

  permissions            Json?      @default("[]")

  resetPasswordCode      String?
  resetPasswordExpiresAt DateTime?

  refreshTokenHash      String?
  refreshTokenExpiresAt DateTime?

  refreshTokenVersion   Int      @default(0)

  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  timeRecords          TimeRecord[]
  reviewedRecords      TimeRecord[]        @relation("TimeRecordReviewer")
  justifications Justification[]
  notifications  Notification[]
  activityLogs        ActivityLog[]       @relation("ActivityLogActor")
  targetedActivityLogs ActivityLog[]       @relation("ActivityLogTarget")
  documents           Document[]
  uploadedDocuments   Document[]          @relation("DocumentUploader")
  pointEvents         PointEvent[]
  integrations        Integration[]
  termAcceptance      TermAcceptance?
  faceRegistration    FaceRegistration?

  @@index([companyId])
  @@index([email])
  @@index([role])
  @@index([cpf])
  @@map("users")
}

model TimeRecord {
  id              String       @id @default(cuid())
  clockIn         String
  clockOut        String?
  breakStart      String?
  breakEnd        String?
  totalMinutes    Int?
  overtimeMinutes Int          @default(0)
  status          RecordStatus @default(NORMAL)
  description     String?
  date            DateTime     @map("date") @db.Date
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  reviewStatus   TimeRecordReviewStatus? @default(PENDING_REVIEW)
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewNote     String?

  reviewer       User? @relation("TimeRecordReviewer", fields: [reviewedBy], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  pointEvents PointEvent[]

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@index([status])
  @@map("time_records")
}

model PointEvent {
  id              String    @id @default(cuid())
  pointType       PointType
  timeValue       String
  recordedAt      DateTime  @default(now())
  latitude        Float?
  longitude       Float?
  locationAccuracy Float?
  locationAddress String?
  locationCity    String?
  locationState   String?
  deviceInfo      Json?
  photoData       String?
  hasPhoto        Boolean   @default(false)
  passwordVerified Boolean  @default(false)
  faceVerified    Boolean?
  date            DateTime  @map("date") @db.Date

  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeRecordId String?
  timeRecord   TimeRecord? @relation(fields: [timeRecordId], references: [id])

  @@index([userId, date])
  @@index([date])
  @@map("point_events")
}

model Justification {
  id            String              @id @default(cuid())
  reason        String
  description   String?
  status        JustificationStatus @default(PENDING)
  rhResponse    String?
  startDate     DateTime            @db.Date
  endDate       DateTime            @db.Date
  attachmentUrl String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  respondedBy String?

  @@index([userId])
  @@index([status])
  @@map("justifications")
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType @default(INFO)
  read      Boolean          @default(false)
  link      String?
  metadata  Json?
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([userId, read])
  @@map("notifications")
}

model ActivityLog {
  id           String   @id @default(cuid())
  action       String
  description  String?
  entityType   String?
  entityId     String?
  oldValue     String?
  newValue     String?
  metadata     Json?
  timestamp    DateTime @default(now())

  userId       String
  user         User     @relation("ActivityLogActor", fields: [userId], references: [id], onDelete: Cascade)
  targetUserId String?
  targetUser   User?    @relation("ActivityLogTarget", fields: [targetUserId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@map("activity_logs")
}

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String
  category    String
  fileUrl     String
  fileSize    Int?
  mimeType    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploadedBy  String
  uploader    User     @relation("DocumentUploader", fields: [uploadedBy], references: [id])

  @@index([userId])
  @@index([category])
  @@index([type])
  @@map("documents")
}

model Integration {
  id             String              @id @default(cuid())
  provider       IntegrationProvider
  name           String
  description    String?
  isConnected    Boolean             @default(false)
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  lastSyncAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("integrations")
}

model TermAcceptance {
  id        String   @id @default(cuid())
  acceptedAt DateTime @default(now())
  ip        String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("term_acceptances")
}

model FaceRegistration {
  id          String   @id @default(cuid())
  status      String   @default("COMPLETED")
  descriptors Json?
  images      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("face_registrations")
}
